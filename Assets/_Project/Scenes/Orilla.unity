--- !u!114 &785397324
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 785397323}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5374bf6959724364c9602c33ec751382, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  panelA: {fileID: 127843405}
  panelB: {fileID: 1766400794}
  textA: {fileID: 33007780}
  textB: {fileID: 2067331691}
  typingSpeed: 0.05
  visibleDuration: 2
  dialogueLines:
  - isCharacterA: 1
    text: (Que hermoso)
  - isCharacterA: 0
    text: "Se\xF1orita, todav\xEDa est\xE1 a tiempo de regresar al pueblo \n"
  - isCharacterA: 0
    text: "Si desea, me da la orden y con \u201CLa sirena\u201D damos vuelta en u"
  - isCharacterA: 1
    text: "Nadie en el pueblo quiere contar lo que est\xE1 pasando en las minas "
  - isCharacterA: 0
    text: "Tengo miedo de lo que le podr\xEDa pasar si la ven los mineros "
  - isCharacterA: 1
    text: "Conozco las consecuencias se\xF1or Segundo\r\nSoy periodista \r\n"
  - isCharacterA: 0
    text: "\u2026\r\n"
  - isCharacterA: 0
    text: "\u2026\r\n"
  - isCharacterA: 0
    text: Llegamos
